# Local development only — feeds `npm run dev` / `start` and the CLI tools
# (import:motomoshi, ocr:test) via --env-file. Copy to .env and fill in.
#
# Production config is NOT here: when deployed inside nexus, storage uses a
# managed identity and the Azure OpenAI key comes from Key Vault — all set as
# Function App App Settings by azure-iac. The app reads whatever is in the
# environment, so nothing in this file is needed in the cloud.

# --- Server ---
# HOST: use 0.0.0.0 to reach it from your phone over LAN.
HOST=127.0.0.1
PORT=8787

# --- Storage ---
# Unset = the Azurite emulator (the `npm run dev` script starts Azurite for you).
# AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# --- Azure OpenAI ---
# Needed for OCR locally; leave the key blank to skip OCR.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-nano
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Geocoding (optional) ---
# Nominatim asks for a unique User-Agent identifying your app.
NOMINATIM_USER_AGENT="tankstelle/0.1 (local-dev)"

# --- Defaults ---
DEFAULT_CURRENCY=EUR

# --- Auth (Microsoft Entra ID) ---
# Leave unset for local dev — the API runs open. Token validation is handled by
# the host's Easy Auth platform layer (see azure-iac); this app only authorizes
# the owner. In production OWNER_OID is set as an App Setting by azure-iac and
# the API then requires the request's oid claim to match it. (Non-secret id.)
# OWNER_OID=<your-user-object-id>

# --- CORS ---
# Comma-separated allowed browser origins (the SPA subdomains). Unset = any
# origin (fine for local dev; the token still gates access in prod).
# CORS_ALLOWED_ORIGINS=https://tankstelle.example.com,https://app2.example.com
